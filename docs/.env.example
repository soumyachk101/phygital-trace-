# ─────────────────────────────────────────────────────────
# PHYGITAL-TRACE — Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3000

# ── Database (PostgreSQL) ─────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/phygital_trace

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here

# ── IPFS (Pinata) ─────────────────────────────────────────
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key
PINATA_GATEWAY=https://gateway.pinata.cloud

# ── Blockchain (Base L2) ──────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
ATTESTATION_CONTRACT_ADDRESS=0xYourDeployedContractAddress
PRIVATE_KEY_SIGNER=0xYourBackendSignerPrivateKey

# ── AI Service ────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000

# ── AWS S3 (fallback storage) ─────────────────────────────
S3_BUCKET=phygital-trace-media
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=ap-south-1

# ── Alchemy (ERC-4337 Paymaster) ──────────────────────────
ALCHEMY_API_KEY=your_alchemy_api_key
ALCHEMY_POLICY_ID=your_gas_policy_id
