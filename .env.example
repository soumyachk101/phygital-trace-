# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://user:password@localhost:5432/phygital_trace?schema=public"
REDIS_URL="redis://localhost:6379"

# ============================================
# JWT AUTH
# ============================================
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long"
JWT_EXPIRES_IN="7d"

# ============================================
# IPFS (Pinata)
# ============================================
PINATA_API_KEY="your-pinata-api-key"
PINATA_SECRET_KEY="your-pinata-secret-key"
PINATA_GATEWAY_URL="https://gateway.pinata.cloud/ipfs"

# ============================================
# BLOCKCHAIN (Base L2)
# ============================================
BASE_RPC_URL="https://sepolia.base.org"  # Testnet; use https://mainnet.base.org for production
ATTESTATION_CONTRACT_ADDRESS="0x..."      # Deploy and fill in
PRIVATE_KEY_SIGNER="0x..."                # Private key for contract submission (KEEP SECRET)

# ============================================
# AI ANOMALY SERVICE
# ============================================
AI_SERVICE_URL="http://localhost:8000"
AI_SERVICE_API_KEY=""  # Optional

# ============================================
# FILE STORAGE (S3 fallback)
# ============================================
S3_BUCKET="phygital-trace-uploads"
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"

# ============================================
# WEB (Next.js frontend)
# ============================================
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_IPFS_GATEWAY="https://gateway.pinata.cloud/ipfs"
NEXT_PUBLIC_BASE_EXPLORER="https://sepolia.basescan.org"  # Testnet; use https://basescan.org for mainnet
NEXT_PUBLIC_APP_NAME="Phygital-Trace"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_CAPTURE=10      # captures per hour per device
RATE_LIMIT_VERIFY=100      # verifies per minute per IP

# ============================================
# WORKER
# ============================================
WORKER_CONCURRENCY=5
QUEUE_PROCESS_INTERVAL=5000

# ============================================
# LOGGING
# ============================================
LOG_LEVEL="info"  # debug, info, warn, error
